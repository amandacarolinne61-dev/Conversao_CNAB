SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# Usadas no NAVEGADOR (dashboard em tempo real) - por isso o prefixo
# NEXT_PUBLIC_. NUNCA coloque a service role key aqui: só a chave anon/
# publishable, que é segura de expor no cliente (o acesso dela é limitado
# pelas RLS policies do schema.sql - só enxerga dashboard_stats).
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui
